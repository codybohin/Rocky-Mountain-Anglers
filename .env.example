# Rocky Mountain Anglers — Environment Variables
# Copy this to .env and fill in your values
# Set all of these in Vercel → Project Settings → Environment Variables

# Supabase (required for database + auth + file storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Anthropic (required for AI catch photo verification)
ANTHROPIC_API_KEY=sk-ant-...

# Stripe (required for kit purchases, $5 catch submissions, guide featured listings)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Kit price product IDs (create these in your Stripe dashboard)
STRIPE_KIT_PRICE_ID=price_...

# OpenWeatherMap (optional — for automated fishing reports)
OPENWEATHER_API_KEY=...

# Cron security (generate a random string, use in Vercel cron header)
CRON_SECRET=your-random-cron-secret-string
